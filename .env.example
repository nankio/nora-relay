# Relay configuration template. Copy to `.env.local` (gitignored) and fill in
# real values. On startup the relay auto-loads `.env.local`, then `.env`, from
# the working directory. Precedence (highest first): real environment,
# `.env.local`, `.env`. Never commit the real files.

# SQLite database path. When unset, the relay uses an in-memory store (dev only).
# The schema is created automatically on start. On Fly this points into the
# mounted volume (see fly.toml); locally any writable path works.
#   SQLITE_PATH=/data/nora.db
SQLITE_PATH=

# Optional: listen address (default :8080).
# LISTEN=:8080

# Only needed once, by `cmd/migrate`, to import existing data from a legacy
# Postgres deployment into SQLite. Not used by the relay itself.
#   DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
